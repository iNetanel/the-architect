# The Architect — example environment variables
#
# Copy this file to .env and fill in the values you need.
# .env is gitignored — never commit real secrets.
#
# None of these are required to use The Architect as an end user.
# They are used by the provider CLIs (OpenCode, Claude Code) that
# The Architect wraps, and by developers of The Architect itself.

# OpenRouter API key — can be use by OpenCode when routing to OpenRouter models.
# Get one at https://openrouter.ai/keys
# OPENROUTER_API_KEY="sk-or-v1-..."

# Anthropic API key — used by Claude Code.
# Get one at https://console.anthropic.com/ or just login as part of the Claude Code CLI setup
# ANTHROPIC_API_KEY="sk-ant-..."
